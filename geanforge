#!/bin/bash

################################################################################
# geanforge - Secure Password Generator
# Usage: Production and Homelab Kubernetes
# Supports: X11, Wayland, macOS | OpenSSL, mkpasswd, urandom
#
# SECURITY NOTES:
#   - Uses /dev/urandom as primary CSPRNG source
#   - Never passes passwords via command-line arguments to hash tools (stdin only)
#   - Cleans sensitive variables via trap on EXIT, SIGINT, SIGTERM, SIGHUP
#   - Creates output files atomically with correct permissions (no race window)
#   - Base64 encoding with hash methods applies to the HASH (not plaintext)
#     Use -S to also display the plaintext password when using hash methods
#
# FEATURES:
#   - Cryptographically secure password generation via /dev/urandom or OpenSSL
#   - Multiple hash methods: bcrypt (htpasswd), SHA-512 (mkpasswd/openssl)
#   - Diceware-style passphrases with custom wordlists
#   - PIN generation (no leading zeros for octal-safe compatibility)
#   - Base64 encoding for Kubernetes secrets
#   - Cross-platform clipboard support (X11, Wayland, macOS)
#   - Auto-clearing clipboard after 30 seconds
#   - Password strength verification via cracklib
#   - System entropy validation
#   - Configurable via environment variables
#
# ENVIRONMENT VARIABLES:
#   DEBUG=1                  Enable verbose debug output
#   FORCE_LOW_ENTROPY=1      Bypass entropy check without prompting
#   NO_COLOR=1               Disable colored output
#   GEANFORGE_MAX_LENGTH     Override maximum password length (default: 256)
#   GEANFORGE_MAX_QUANTITY   Override maximum password count (default: 100)
#   GEANFORGE_MIN_ENTROPY    Override minimum entropy requirement (default: 1000)
#   GEANFORGE_MAX_PIN_DIGITS Override maximum PIN digits (default: 12)
#   GEANFORGE_MIN_WORDS      Override minimum passphrase words (default: 4)
#   GEANFORGE_MAX_WORD_SEP_LENGTH Override max word separator length (default: 10)
################################################################################

set -euo pipefail

# --- Colors (using printf consistently, respecting NO_COLOR) -------------------------
if [[ "${NO_COLOR:-0}" == "1" ]] || ! [[ -t 1 ]]; then
    readonly RED='' GREEN='' YELLOW='' BLUE='' CYAN='' MAGENTA='' NC=''
else
    readonly RED='\033[0;31m'
    readonly GREEN='\033[0;32m'
    readonly YELLOW='\033[1;33m'
    readonly BLUE='\033[0;34m'
    readonly CYAN='\033[0;36m'
    readonly MAGENTA='\033[0;35m'
    readonly NC='\033[0m'
fi

# --- Security limits (configurable via environment) ----------------------------------
readonly MAX_LENGTH="${GEANFORGE_MAX_LENGTH:-256}"
readonly MAX_QUANTITY="${GEANFORGE_MAX_QUANTITY:-100}"
readonly MIN_ENTROPY="${GEANFORGE_MIN_ENTROPY:-1000}"
readonly MAX_PIN_DIGITS="${GEANFORGE_MAX_PIN_DIGITS:-12}"
readonly MIN_WORDS="${GEANFORGE_MIN_WORDS:-4}"
readonly MAX_WORD_SEP_LENGTH="${GEANFORGE_MAX_WORD_SEP_LENGTH:-10}"

# --- Wordlist directories --------------------------------------------------------------
readonly WORDLISTS=(
    "/usr/share/dict/words"
    "/usr/share/dict/american-english"
    "/usr/share/dict/brazilian"
    "/usr/share/dict/portuguese"
    "/usr/share/dict/cracklib-words"
)

# --- Logging functions (printf-based for POSIX compatibility) ---------------------------
_msg() {
    local color="$1"
    local label="$2"
    shift 2
    printf "${color}[%s]${NC} %s\n" "$label" "$*"
}
_info()    { _msg "$BLUE"    "INFO"    "$@"; }
_warn()    { _msg "$YELLOW" "WARN"    "$@"; }
_error()   { _msg "$RED"     "ERROR"   "$@" >&2; }
_success() { _msg "$GREEN"   "SUCCESS" "$@"; }
_debug()   { [[ "${DEBUG:-0}" == "1" ]] && _msg "$MAGENTA" "DEBUG" "$@" >&2 || true; }

# --- Secure memory cleanup (simplified logic) ------------------------------------------
_cleanup_sensitive_vars() {
    # Overwrite variables that might contain passwords (best effort in bash)
    local vars=("_LAST_PASSWORD" "_LAST_CLIPBOARD" "_PLAIN_PASSWORD" "_TMP_OUTPUT")
    for v in "${vars[@]}"; do
        eval "$v=''" 2>/dev/null || true
    done
    unset _LAST_PASSWORD _LAST_CLIPBOARD _PLAIN_PASSWORD _TMP_OUTPUT 2>/dev/null || true
}

trap '_cleanup_sensitive_vars' EXIT SIGINT SIGTERM SIGHUP

# --- Command verification --------------------------------------------------------------
command_exists() { command -v "$1" &>/dev/null; }

# --- System entropy verification -------------------------------------------------------
_check_entropy() {
    if [[ -r /proc/sys/kernel/random/entropy_avail ]]; then
        local entropy
        entropy=$(cat /proc/sys/kernel/random/entropy_avail 2>/dev/null || echo 0)
        _debug "Available entropy: $entropy bits"
        if [[ "$entropy" -lt "$MIN_ENTROPY" ]]; then
            _warn "Low system entropy ($entropy bits). Consider installing haveged or rng-tools"
            _warn "On freshly booted VMs, wait a few seconds and try again"
            if [[ "${FORCE_LOW_ENTROPY:-0}" != "1" ]]; then
                if [[ -t 0 ]]; then
                    local response=""
                    read -rp "Continue anyway? [y/N]: " response
                    [[ "$response" =~ ^[Yy]$ ]] || return 1
                else
                    _error "Non-interactive mode: low entropy detected. Use --force-low-entropy to override."
                    return 1
                fi
            fi
        fi
    fi
}

# --- Clipboard environment detection (with functional test) ----------------------------
_detect_clipboard() {
    if [[ -n "${WAYLAND_DISPLAY:-}" ]] && command_exists wl-copy; then
        if printf '' | wl-copy 2>/dev/null; then
            echo "wayland"
            return 0
        fi
    fi
    if [[ -n "${DISPLAY:-}" ]] && command_exists xclip; then
        if printf '' | xclip -selection clipboard 2>/dev/null; then
            echo "x11"
            return 0
        fi
    fi
    if command_exists pbcopy; then
        if printf '' | pbcopy 2>/dev/null; then
            echo "macos"
            return 0
        fi
    fi
    echo "none"
}

# --- Secure clipboard copy (uses cached clipboard type) --------------------------------
_copy_clipboard() {
    local text="$1"
    local mode="${2:-copy}"   # copy | clear
    local clipboard_type="${_CLIPBOARD_TYPE:-none}"

    case "$clipboard_type" in
        wayland)
            if [[ "$mode" == "clear" ]]; then
                wl-copy --clear 2>/dev/null && return 0
            else
                printf '%s' "$text" | wl-copy 2>/dev/null && return 0
            fi
            ;;
        x11)
            if [[ "$mode" == "clear" ]]; then
                if command_exists xsel; then
                    printf '' | xsel --clipboard --input 2>/dev/null && return 0
                fi
                printf '' | xclip -selection clipboard 2>/dev/null && return 0
            else
                printf '%s' "$text" | xclip -selection clipboard 2>/dev/null && return 0
            fi
            ;;
        macos)
            if [[ "$mode" == "clear" ]]; then
                printf '' | pbcopy 2>/dev/null && return 0
            else
                printf '%s' "$text" | pbcopy 2>/dev/null && return 0
            fi
            ;;
    esac
    return 1
}

# --- Clear clipboard with timeout (with session health check) --------------------------
_schedule_clipboard_clear() {
    local delay_sec="${1:-30}"
    local clipboard_type="${_CLIPBOARD_TYPE:-none}"
    (
        trap '' SIGHUP SIGTERM SIGINT
        local elapsed=0
        while [[ "$elapsed" -lt "$delay_sec" ]]; do
            sleep 1
            # Check if session/display still alive
            case "$clipboard_type" in
                wayland)
                    [[ -n "${WAYLAND_DISPLAY:-}" ]] || break
                    ;;
                x11)
                    [[ -n "${DISPLAY:-}" ]] || break
                    ;;
            esac
            ((elapsed++))
        done
        _copy_clipboard "" "clear" 2>/dev/null || true
    ) &
    disown 2>/dev/null || true
    _info "Clipboard auto-clear scheduled in ${delay_sec}s"
}

# --- Validate charset (prevents edge cases) --------------------------------------------
_validate_charset() {
    local charset="$1"
    if [[ ${#charset} -lt 2 ]]; then
        _error "Charset must have at least 2 unique characters (got ${#charset})"
        return 1
    fi
    return 0
}

# --- Character set generation ----------------------------------------------------------
_generate_charset() {
    local hex_only="$1"
    local use_symbols="$2"
    local no_ambiguous="$3"

    if [[ "$hex_only" == true ]]; then
        printf '%s' '0123456789ABCDEF'
    elif [[ "$no_ambiguous" == true ]]; then
        if [[ "$use_symbols" == true ]]; then
            printf '%s' 'abcdefghijkmnpqrstuvwxyzABCDEFGHJKLMNPQRSTUVWXYZ23456789!@#%^&*_=+[]{}:,.?~'
        else
            printf '%s' 'abcdefghijkmnpqrstuvwxyzABCDEFGHJKLMNPQRSTUVWXYZ23456789'
        fi
    elif [[ "$use_symbols" == true ]]; then
        printf '%s' 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789!@#%^&*_=+[]{}:,.?~'
    else
        printf '%s' 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789'
    fi
}

# --- Generate via /dev/urandom (primary CSPRNG, no SIGPIPE/race) ---------------------
_generate_password_urandom() {
    local length="$1"
    local charset="$2"
    local filtered
    local tmpfile

    _validate_charset "$charset" || return 1

    # Read a buffer larger than needed to account for filtering losses
    # For a charset of ~62 chars, each byte has ~40% chance of being accepted
    # We read 8x the length to have >99.99% probability of success
    local bytes_needed=$(( length * 8 ))

    # Use a temporary file to avoid null-byte issues in bash command substitution
    tmpfile=$(mktemp "${TMPDIR:-/tmp}/gf.XXXXXX")
    chmod 600 "$tmpfile"

    if ! LC_ALL=C dd if=/dev/urandom bs=1 count="$bytes_needed" iflag=fullblock 2>/dev/null > "$tmpfile"; then
        rm -f "$tmpfile"
        _error "Failed to read from /dev/urandom"
        return 1
    fi

    filtered=$(LC_ALL=C tr -dc "$charset" < "$tmpfile")
    rm -f "$tmpfile"

    if [[ "${#filtered}" -lt "$length" ]]; then
        _error "Insufficient entropy after filtering (got ${#filtered}, need $length)"
        return 1
    fi

    printf '%s' "${filtered:0:length}"
}

# --- Generate via openssl with bias reduction (no head -c in pipeline) -----------------
_generate_password_openssl_rand() {
    local length="$1"
    local no_ambiguous="${2:-false}"

    local charset
    if [[ "$no_ambiguous" == true ]]; then
        charset="a-km-np-zA-KM-NP-Z2-9"
    else
        charset="A-Za-z0-9"
    fi

    # openssl rand outputs binary; we use base64 to get printable chars,
    # then tr filters. Base64 has 64 chars; if we need ~62, we read enough.
    local bytes_needed=$(( length * 8 ))
    local raw filtered

    raw=$(openssl rand "$bytes_needed" 2>/dev/null | base64 | tr -dc "$charset")

    if [[ "${#raw}" -lt "$length" ]]; then
        _error "OpenSSL rand produced insufficient characters after filtering"
        return 1
    fi

    printf '%s' "${raw:0:length}"
}

# --- Generate numeric PIN (simple, secure, no leading zeros) ---------------------------
_generate_pin() {
    local digits="$1"
    local first rest
    local tmpfile

    # Use a temporary file to avoid null-byte issues in bash command substitution
    tmpfile=$(mktemp "${TMPDIR:-/tmp}/gf.XXXXXX")
    chmod 600 "$tmpfile"

    if ! LC_ALL=C dd if=/dev/urandom bs=1 count=$(( digits * 8 )) iflag=fullblock 2>/dev/null > "$tmpfile"; then
        rm -f "$tmpfile"
        _error "Failed to read from /dev/urandom for PIN"
        return 1
    fi

    # First digit: 1-9 (avoid leading zero for octal-safe compatibility)
    first=$(LC_ALL=C tr -dc '1-9' < "$tmpfile" | LC_ALL=C cut -c1)
    [[ -n "$first" ]] || { rm -f "$tmpfile"; _error "Failed to generate first PIN digit"; return 1; }

    if [[ "$digits" -eq 1 ]]; then
        rm -f "$tmpfile"
        printf '%s' "$first"
        return 0
    fi

    # Remaining digits: 0-9 allowed
    rest=$(LC_ALL=C tr -dc '0-9' < "$tmpfile" | LC_ALL=C cut -c2-$((digits)))
    rm -f "$tmpfile"
    [[ -n "$rest" ]] || { _error "Failed to generate remaining PIN digits"; return 1; }

    printf '%s%s' "$first" "$rest"
}

# --- Generate Diceware-style passphrase ------------------------------------------------
_generate_passphrase() {
    local num_words="$1"
    local separator="${2:--}"

    if ! command_exists shuf; then
        _error "\`shuf\` (GNU coreutils) is required for passphrase generation."
        _error "Install: sudo apt install coreutils | sudo dnf install coreutils | brew install coreutils"
        return 1
    fi

    local wordlist=""
    for wl in "${WORDLISTS[@]}"; do
        if [[ -r "$wl" ]]; then
            local line_count
            line_count=$(wc -l < "$wl" 2>/dev/null || echo 0)
            if [[ "$line_count" -gt 1000 ]]; then
                wordlist="$wl"
                _debug "Using wordlist: $wordlist ($line_count words)"
                break
            fi
        fi
    done

    if [[ -z "$wordlist" ]]; then
        _error "No suitable wordlist found (need >1000 words, readable)."
        _error "Install: sudo apt install wamerican wbritish | sudo dnf install words"
        return 1
    fi

    shuf -n "$num_words" "$wordlist" 2>/dev/null | paste -sd "$separator" -
}

# --- Password strength verification (returns status code) ------------------------------
_check_strength() {
    local password="$1"
    local length="${#password}"
    local has_upper=0 has_lower=0 has_number=0 has_symbol=0

    [[ "$password" =~ [A-Z] ]] && has_upper=1
    [[ "$password" =~ [a-z] ]] && has_lower=1
    [[ "$password" =~ [0-9] ]] && has_number=1
    [[ "$password" =~ [^A-Za-z0-9] ]] && has_symbol=1

    local score=$((has_upper + has_lower + has_number + has_symbol))
    local strength_status=0

    if [[ "$length" -lt 8 ]]; then
        _warn "Password too short ($length chars) — Very Weak"
        strength_status=1
    elif [[ "$length" -lt 12 && "$score" -lt 3 ]]; then
        _warn "Short password with low character variety — Weak"
        strength_status=1
    elif [[ "$score" -lt 3 ]]; then
        _warn "Password lacks character variety — Medium"
        strength_status=1
    fi

    if command_exists cracklib-check && [[ "$length" -lt 20 ]]; then
        local check_result
        check_result=$(printf '%s\n' "$password" | cracklib-check 2>/dev/null || true)
        # Normalize to lowercase ASCII for locale-safe matching
        check_result=$(LC_ALL=C printf '%s' "$check_result" | LC_ALL=C tr '[:upper:]' '[:lower:]')
        if [[ "$check_result" =~ (dictionary|too simple|simple) ]]; then
            _warn "cracklib: Password contains dictionary words or predictable patterns"
            strength_status=1
        fi
    fi

    return "$strength_status"
}

# --- Hash functions (stdin-based to avoid ps visibility) -------------------------------
_generate_hash_mkpasswd() {
    local password="$1"
    local method="${2:-SHA-512}"

    # Try stdin-capable mkpasswd first (whois package on some distros supports -s)
    if printf '%s' "$password" | mkpasswd -S '' -m "$method" -s 2>/dev/null; then
        return 0
    fi

    # Fallback: openssl passwd -6 (SHA-512) which reliably supports stdin
    _warn "mkpasswd stdin failed (whois package may not support -s). Using openssl fallback."
    printf '%s' "$password" | openssl passwd -6 -stdin 2>/dev/null
}

_generate_hash_openssl() {
    local password="$1"
    printf '%s' "$password" | openssl passwd -6 -stdin 2>/dev/null
}

_generate_hash_bcrypt() {
    local password="$1"
    local cost="${2:-10}"
    # -n: stdout, -i: stdin, -B: bcrypt, -C: cost
    printf '%s' "$password" | htpasswd -niBC "$cost" "" 2>/dev/null | cut -d: -f2
}

# --- Base64 encoding (for Kubernetes secrets) ------------------------------------------
_encode_base64() {
    local text="$1"
    local multi_line="${2:-false}"

    # Test functionality instead of parsing --help (more reliable across locales)
    if printf 'test' | base64 -w 0 &>/dev/null; then
        # GNU base64
        if [[ "$multi_line" == true ]]; then
            printf '%s' "$text" | base64
        else
            printf '%s' "$text" | base64 -w 0
        fi
    else
        # BSD/macOS base64
        if [[ "$multi_line" == true ]]; then
            printf '%s' "$text" | base64
        else
            printf '%s' "$text" | base64 | tr -d '\n'
        fi
    fi
}

# --- Help ------------------------------------------------------------------------------
show_help() {
    cat << 'EOF'
Usage: geanforge [OPTIONS]

Generates secure random passwords, PINs, passphrases, or hashes for production.

Main Options:
  -l, --length N         Password length (default: 20, max: 256)
  -n, --count N          Number of passwords (default: 1, max: 100)
  -m, --method METHOD    Method: random, openssl-rand, mkpasswd, openssl, bcrypt
                         (default: random)

Special Modes:
  -p, --pin N            Generate numeric PIN of N digits (max: 12)
                         (avoids leading zero for octal-safe compatibility)
  -w, --words N          Generate passphrase with N words (Diceware-style, min: 4)
                         (requires: shuf from coreutils, and a wordlist)
  -W, --word-sep CHAR    Separator for passphrase (default: -, max length: 10)
  -b, --base64           Convert output to base64 (ideal for K8s secrets)
                         Note: With hash methods, base64 encodes the HASH output.
                         Use -S to also see the plaintext password.

Character Configuration:
  -s, --no-symbols       Alphanumeric only (no special characters)
  -a, --no-ambiguous     Remove visually ambiguous chars: 0 O l 1 I
  -x, --hexadecimal      Hexadecimal output only (0-9, A-F)
  -e, --entropy          Check system entropy before generating

Output:
  -S, --show-password    Show plaintext password alongside hash (hash methods only)
  -C, --clipboard        Copy last password/hash to clipboard (auto-detects X11/Wayland)
  -f, --file FILE        Save to file (perm 600) with metadata header
  --cost N               Cost factor for bcrypt (default: 10, range: 4-31)

Security:
  -F, --strength         Verify generated password strength (random method
                         excluding PIN and base64-encoded output)
  --force-low-entropy    Skip low entropy warning and prompt

Environment:
  NO_COLOR=1             Disable colored output
  DEBUG=1                Enable verbose debug output
  FORCE_LOW_ENTROPY=1    Bypass entropy check without prompting

Examples:
  # Basic 20-char password via /dev/urandom
  geanforge

  # 6-digit PIN (2FA/banking)
  geanforge -p 6

  # Memorable 5-word passphrase
  geanforge -w 5

  # Bcrypt hash for web application (shows hash + plaintext)
  geanforge -l 16 -m bcrypt --cost 12 -S

  # 10x 32-char passwords saved securely
  geanforge -n 10 -l 32 -f passwords-k8s.txt

  # Base64-encoded password for Kubernetes secret
  geanforge -l 32 -b

  # Strong password with clipboard copy and strength check
  geanforge -l 24 -a -F -C

Kubernetes Integration:
  # Generate secret directly (plaintext password in kubectl command visible in ps!)
  kubectl create secret generic app-secret \
    --from-literal=password="$(geanforge -l 32 -s)"

  # Base64-encoded value (for manual secret YAML)
  geanforge -l 32 -b

Environment Variables:
  DEBUG=1                Enable verbose debug output
  FORCE_LOW_ENTROPY=1    Bypass entropy check without prompting
  GEANFORGE_MAX_LENGTH=N Override maximum password length (default: 256)
  GEANFORGE_MAX_QUANTITY=N Override maximum password count (default: 100)
  GEANFORGE_MIN_ENTROPY=N Override minimum entropy requirement (default: 1000)

EOF
}

# ========================================================================================
# MAIN
# ========================================================================================
main() {
    # --- Defaults -----------------------------------------------------------------------
    local length=20
    local use_symbols=true
    local count=1
    local hex_only=false
    local no_ambiguous=false
    local method="random"
    local show_password=false
    local copy_clipboard=false
    local output_file=""
    local check_strength=false
    local check_entropy=false
    local pin_mode=false
    local passphrase_mode=false
    local num_words=0
    local word_separator="-"
    local bcrypt_cost=10
    local encode_base64=false

    # --- Argument parsing ---------------------------------------------------------------
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -l|--length)
                [[ -n "${2:-}" ]] || { _error "Option $1 requires a value"; exit 1; }
                [[ "$2" =~ ^- ]] && { _error "Option $1 value cannot start with '-'"; exit 1; }
                [[ "$2" =~ ^[0-9]+$ ]] && [[ "$2" -gt 0 ]] || { _error "Length must be a positive integer"; exit 1; }
                length="$2"
                shift 2
                ;;
            -n|--count)
                [[ -n "${2:-}" ]] || { _error "Option $1 requires a value"; exit 1; }
                [[ "$2" =~ ^- ]] && { _error "Option $1 value cannot start with '-'"; exit 1; }
                [[ "$2" =~ ^[0-9]+$ ]] && [[ "$2" -gt 0 ]] || { _error "Count must be a positive integer"; exit 1; }
                count="$2"
                shift 2
                ;;
            -p|--pin)
                [[ -n "${2:-}" ]] || { _error "Option $1 requires a value"; exit 1; }
                [[ "$2" =~ ^- ]] && { _error "Option $1 value cannot start with '-'"; exit 1; }
                [[ "$2" =~ ^[0-9]+$ ]] && [[ "$2" -gt 0 ]] && [[ "$2" -le "$MAX_PIN_DIGITS" ]] || {
                    _error "PIN must have 1-$MAX_PIN_DIGITS digits"; exit 1;
                }
                pin_mode=true
                length="$2"
                shift 2
                ;;
            -w|--words)
                [[ -n "${2:-}" ]] || { _error "Option $1 requires a value"; exit 1; }
                [[ "$2" =~ ^- ]] && { _error "Option $1 value cannot start with '-'"; exit 1; }
                [[ "$2" =~ ^[0-9]+$ ]] && [[ "$2" -ge "$MIN_WORDS" ]] || {
                    _error "Passphrase must have at least $MIN_WORDS words"; exit 1;
                }
                passphrase_mode=true
                num_words="$2"
                shift 2
                ;;
            -W|--word-sep)
                [[ -n "${2:-}" ]] || { _error "Option $1 requires a value"; exit 1; }
                [[ ${#2} -le "$MAX_WORD_SEP_LENGTH" ]] || {
                    _error "Word separator too long (max $MAX_WORD_SEP_LENGTH chars, got ${#2})"; exit 1;
                }
                word_separator="$2"
                shift 2
                ;;
            -s|--no-symbols)
                use_symbols=false
                shift
                ;;
            -a|--no-ambiguous)
                no_ambiguous=true
                shift
                ;;
            -x|--hexadecimal)
                hex_only=true
                shift
                ;;
            -m|--method)
                [[ -n "${2:-}" ]] || { _error "Option $1 requires a value"; exit 1; }
                case "$2" in
                    random|openssl-rand|mkpasswd|openssl|bcrypt) method="$2" ;;
                    *) _error "Invalid method. Valid: random, openssl-rand, mkpasswd, openssl, bcrypt"; exit 1 ;;
                esac
                shift 2
                ;;
            --cost)
                [[ -n "${2:-}" ]] || { _error "Option $1 requires a value"; exit 1; }
                [[ "$2" =~ ^- ]] && { _error "Option $1 value cannot start with '-'"; exit 1; }
                [[ "$2" =~ ^[0-9]+$ ]] && [[ "$2" -ge 4 ]] && [[ "$2" -le 31 ]] || {
                    _error "Bcrypt cost must be 4-31 (inclusive)"; exit 1;
                }
                bcrypt_cost="$2"
                shift 2
                ;;
            -S|--show-password)
                show_password=true
                shift
                ;;
            -C|--clipboard)
                copy_clipboard=true
                shift
                ;;
            -f|--file)
                [[ -n "${2:-}" ]] || { _error "Option $1 requires a value"; exit 1; }
                output_file="$2"
                shift 2
                ;;
            -F|--strength)
                check_strength=true
                shift
                ;;
            -e|--entropy)
                check_entropy=true
                shift
                ;;
            --force-low-entropy)
                export FORCE_LOW_ENTROPY=1
                shift
                ;;
            -b|--base64)
                encode_base64=true
                shift
                ;;
            -h|--help)
                show_help
                exit 0
                ;;
            *)
                _error "Unknown option: $1"
                show_help
                exit 1
                ;;
        esac
    done

    # --- Incompatible combination validations ---------------------------------------------
    if [[ "$pin_mode" == true && "$passphrase_mode" == true ]]; then
        _error "Cannot use --pin and --words simultaneously"
        exit 1
    fi

    if [[ "$hex_only" == true && "$no_ambiguous" == true ]]; then
        _error "--hexadecimal and --no-ambiguous are mutually exclusive"
        exit 1
    fi

    if [[ "$passphrase_mode" == true ]]; then
        if [[ "$hex_only" == true || "$no_ambiguous" == true || "$use_symbols" == false ]]; then
            _error "Character options (--no-symbols, --no-ambiguous, --hexadecimal) do not apply to passphrases"
            exit 1
        fi
    fi

    # --- Global limits ------------------------------------------------------------------
    if [[ "$length" -gt "$MAX_LENGTH" ]]; then
        _error "Maximum password length: $MAX_LENGTH"
        exit 1
    fi
    if [[ "$count" -gt "$MAX_QUANTITY" ]]; then
        _error "Maximum password count: $MAX_QUANTITY"
        exit 1
    fi

    # --- PIN-specific length validation -------------------------------------------------
    if [[ "$pin_mode" == true && "$length" -gt "$MAX_PIN_DIGITS" ]]; then
        _error "PIN length cannot exceed $MAX_PIN_DIGITS digits"
        exit 1
    fi

    # --- Entropy verification -----------------------------------------------------------
    if [[ "$check_entropy" == true ]] || { [[ "$pin_mode" == false ]] && [[ "$length" -gt 32 ]]; }; then
        _check_entropy || exit 1
    fi

    # --- Method dependency verification -------------------------------------------------
    case "$method" in
        mkpasswd)
            command_exists mkpasswd || { _error "mkpasswd not found. Install: sudo apt install whois"; exit 1; }
            ;;
        openssl|openssl-rand)
            command_exists openssl || { _error "OpenSSL not installed"; exit 1; }
            ;;
        bcrypt)
            command_exists htpasswd || {
                _error "htpasswd not found. Install:"
                _error "  Debian/Ubuntu: sudo apt install apache2-utils"
                _error "  RHEL/Fedora:   sudo dnf install httpd-tools"
                _error "  macOS:         brew install httpd"
                exit 1
            }
            # Verify htpasswd supports stdin (-i flag)
            if ! printf 'test' | htpasswd -niBC 10 "" &>/dev/null; then
                _error "htpasswd version does not support stdin (-i). Upgrade apache2-utils/httpd-tools"
                exit 1
            fi
            ;;
    esac

    # --- Output file setup (atomic, no race condition) ----------------------------------
    local _TMP_OUTPUT=""
    if [[ -n "$output_file" ]]; then
        # Write to temp file first, move atomically at the end
        _TMP_OUTPUT=$(mktemp "${output_file}.tmp.XXXXXX")
        chmod 600 "$_TMP_OUTPUT" || { _error "Cannot set permissions on temp file"; exit 1; }

        {
            echo "# ==========================================="
            echo "# Generated by: geanforge"
            echo "# Date: $(date +%Y-%m-%dT%H:%M:%S%z)"
            echo "# Host: $(hostname)"
            echo "# User: $(whoami)"
            echo "# Method: $method"
            if [[ "$passphrase_mode" == true ]]; then
                echo "# Words: $num_words | Separator: $word_separator"
            else
                echo "# Length: $length | Count: $count"
            fi
            [[ "$encode_base64" == true ]] && echo "# Encoding: base64"
            echo "# WARNING: Remove this file after use (auto-destruction in 24h recommended)"
            echo "# ==========================================="
        } >> "$_TMP_OUTPUT"
    fi

    # --- Informational header -----------------------------------------------------------
    if [[ "$pin_mode" == true ]]; then
        _info "Generating PIN with $length digits..."
    elif [[ "$passphrase_mode" == true ]]; then
        _info "Generating Diceware passphrase ($num_words words)..."
    else
        case "$method" in
            random)       _info "Generating via /dev/urandom (CSPRNG)..." ;;
            openssl-rand) _info "Generating via OpenSSL..." ;;
            mkpasswd)     _info "Generating SHA-512 hash (whois mkpasswd)..." ;;
            openssl)      _info "Generating SHA-512 hash (OpenSSL)..." ;;
            bcrypt)       _info "Generating Bcrypt hash (cost: $bcrypt_cost)..." ;;
        esac
    fi

    # --- Pre-compute charset (optimization) ---------------------------------------------
    local charset=""
    if [[ "$passphrase_mode" == false && "$pin_mode" == false ]]; then
        case "$method" in
            random|mkpasswd|openssl|bcrypt)
                charset=$(_generate_charset "$hex_only" "$use_symbols" "$no_ambiguous")
                ;;
        esac
    fi

    # --- Clipboard setup (cached detection) ---------------------------------------------
    local _CLIPBOARD_TYPE
    _CLIPBOARD_TYPE=$(_detect_clipboard)

    if [[ "$copy_clipboard" == true ]]; then
        if [[ "$_CLIPBOARD_TYPE" == "none" ]]; then
            _warn "No clipboard tool detected (install: wl-clipboard, xclip, or pbcopy)"
            copy_clipboard=false
        else
            _debug "Clipboard detected: $_CLIPBOARD_TYPE"
        fi
    fi

    # --- Local state for clipboard (minimize global exposure) ----------------------------
    local _LAST_PASSWORD=""
    local _LAST_CLIPBOARD=""

    # ====================================================================================
    # Main generation loop
    # ====================================================================================
    local i password="" plain_password=""
    for ((i=1; i<=count; i++)); do
        [[ "$count" -gt 1 ]] && printf "${CYAN}--- Item %d ---${NC}\n" "$i"

        password=""
        plain_password=""

        # ---- Generation logic ----------------------------------------------------------
        if [[ "$pin_mode" == true ]]; then
            password=$(_generate_pin "$length") || { _error "Failed to generate PIN"; exit 1; }

        elif [[ "$passphrase_mode" == true ]]; then
            password=$(_generate_passphrase "$num_words" "$word_separator") || {
                _error "Failed to generate passphrase"; exit 1;
            }

        else
            case "$method" in
                random)
                    password=$(_generate_password_urandom "$length" "$charset") || {
                        _error "Failed to generate password via /dev/urandom"; exit 1;
                    }
                    ;;

                openssl-rand)
                    password=$(_generate_password_openssl_rand "$length" "$no_ambiguous") || {
                        _error "Failed to generate password via OpenSSL"; exit 1;
                    }
                    ;;

                mkpasswd|openssl|bcrypt)
                    # Generate plaintext password first (local scope, cleaned after loop)
                    plain_password=$(_generate_password_urandom "$length" "$charset") || {
                        _error "Failed to generate base password"; exit 1;
                    }
                    [[ -n "$plain_password" ]] || { _error "Empty password generated"; exit 1; }

                    # Apply hash
                    case "$method" in
                        mkpasswd) password=$(_generate_hash_mkpasswd "$plain_password") ;;
                        openssl)  password=$(_generate_hash_openssl "$plain_password") ;;
                        bcrypt)   password=$(_generate_hash_bcrypt "$plain_password" "$bcrypt_cost") ;;
                    esac

                    if [[ -z "$password" ]]; then
                        _error "Hash generation failed"; exit 1;
                    fi

                    if [[ "$show_password" == true ]]; then
                        printf "${MAGENTA}Plaintext:${NC} ${GREEN}%s${NC}\n" "$plain_password"
                    fi
                    ;;
            esac
        fi

        # ---- Final validation -----------------------------------------------------------
        [[ -n "$password" ]] || { _error "Generated empty output"; exit 1; }

        # ---- Base64 encoding (applies to the displayed output) --------------------------
        if [[ "$encode_base64" == true ]]; then
            password=$(_encode_base64 "$password")
            [[ -n "$password" ]] || { _error "Base64 encoding failed"; exit 1; }
            _debug "Output encoded to base64"
        fi

        # ---- Formatted output -----------------------------------------------------------
        printf "${GREEN}%s${NC}\n" "$password"

        # ---- Strength check (uses return code) ------------------------------------------
        if [[ "$check_strength" == true && "$encode_base64" == false ]]; then
            case "$method" in
                random|openssl-rand)
                    _check_strength "$password" || true
                    ;;
            esac
        fi

        # ---- Persistence to temp file -------------------------------------------------
        [[ -n "$_TMP_OUTPUT" ]] && printf '%s\n' "$password" >> "$_TMP_OUTPUT"

        # ---- Update clipboard candidate (local only) ------------------------------------
        _LAST_PASSWORD="$password"
        _LAST_CLIPBOARD="$password"

        # ---- Clear plaintext immediately if hash mode -----------------------------------
        plain_password=""

        # ---- Visual separator -----------------------------------------------------------
        [[ "$count" -gt 1 && "$i" -lt "$count" ]] && printf '\n'
    done

    # ====================================================================================
    # Post-generation
    # ====================================================================================

    # ---- Atomic move for output file --------------------------------------------------
    if [[ -n "$_TMP_OUTPUT" && -n "$output_file" ]]; then
        if mv -f "$_TMP_OUTPUT" "$output_file"; then
            chmod 600 "$output_file" 2>/dev/null || true
            local line_count
            line_count=$(wc -l < "$output_file" 2>/dev/null || echo "?")
            _success "Saved to: $output_file (permissions: 600, lines: $line_count)"
            _info "Remove after use: rm -f $output_file"
        else
            _error "Failed to move output file to $output_file (temp left at $_TMP_OUTPUT)"
            exit 1
        fi
    fi

    # ---- Clipboard copy ---------------------------------------------------------------
    if [[ "$copy_clipboard" == true && -n "$_LAST_CLIPBOARD" ]]; then
        if _copy_clipboard "$_LAST_CLIPBOARD"; then
            _success "Copied to clipboard ($(tr '[:lower:]' '[:upper:]' <<< "$_CLIPBOARD_TYPE"))"
            _schedule_clipboard_clear 30
        else
            _warn "Failed to copy to clipboard"
        fi
    fi

    # ---- Contextual security warnings ---------------------------------------------------
    if [[ "$length" -lt 12 && "$pin_mode" == false && "$passphrase_mode" == false && "$method" != "bcrypt" && "$method" != "mkpasswd" && "$method" != "openssl" ]]; then
        _warn "Passwords shorter than 12 characters are not recommended for production"
    fi

    case "$method" in
        bcrypt)
            _info "Bcrypt hash ready for modern web frameworks (format: \$2y\$)"
            ;;
        mkpasswd|openssl)
            _info "Hash ready for /etc/shadow or legacy authentication systems"
            ;;
    esac

    [[ "$encode_base64" == true ]] && _info "Base64 values ready for Kubernetes Secret data fields"

    # ---- Final cleanup ------------------------------------------------------------------
    _LAST_PASSWORD=""
    _LAST_CLIPBOARD=""
    _cleanup_sensitive_vars
    return 0
}

main "$@"
